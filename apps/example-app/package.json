{
  "name": "example-app",
  "license": "0BSD",
  "main": "./index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "DISABLE_CODE_SIGNING=true expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "DISABLE_CODE_SIGNING=true expo run:android",
    "ios": "DISABLE_CODE_SIGNING=true expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "release_production": "RELEASE_CHANNEL=production ../eoas/bin/dev.js publish --nonInteractive --branch production --disableRepositoryCheck",
    "release_staging": "RELEASE_CHANNEL=staging ../eoas/bin/dev.js publish --nonInteractive --branch staging --disableRepositoryCheck",
    "create_production_rollback": "RELEASE_CHANNEL=production ../eoas/bin/dev.js rollback --branch production",
    "create_staging_rollback": "RELEASE_CHANNEL=staging ../eoas/bin/dev.js rollback --branch staging",
    "prebuild_production": "RELEASE_CHANNEL=production expo prebuild",
    "prebuild_staging": "RELEASE_CHANNEL=staging expo prebuild"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-picker/picker": "2.11.4",
    "expo": "^56.0.0",
    "expo-blur": "~56.0.4",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.22",
    "expo-dev-client": "~56.0.24",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.16",
    "expo-observe": "~56.0.26",
    "expo-router": "~56.2.16",
    "expo-splash-screen": "~56.0.14",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.23",
    "expo-web-browser": "~56.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-json-tree": "^1.5.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/jest": "^29.5.12",
    "@types/prettier": "^2.4.4",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^18.3.0",
    "eslint": "^9.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.5",
    "prettier": "^2.5.1",
    "react-test-renderer": "18.3.1",
    "typescript": "~6.0.3",
    "eslint-config-expo": "~56.0.4"
  },
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
